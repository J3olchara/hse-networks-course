# Конфигурация сетевых параметров
# Скопируйте этот файл в .env и заполните своими значениями

# IP адрес вашего устройства (найти: ip addr show)
DEVICE_IP=192.168.1.6

# MAC адрес вашего устройства (найти: ip addr show)
DEVICE_MAC=aa:bb:cc:dd:ee:ff

# IP адрес роутера/gateway (найти: ip route | grep default)
ROUTER_IP=192.168.1.1

# Сетевой интерфейс (найти: ip addr show - обычно eth0, wlan0, enp0s3, и т.д.)
NETWORK_INTERFACE=eth0
